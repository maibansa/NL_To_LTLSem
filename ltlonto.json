{
  "LtlLogicOntology": {
    "operators": {
      "tAlways": {
        "type": "future_operator",
        "ltl_pattern": "G( {cond} -> {act} )",
        "useFor": ["safety", "invariants", "continuous states"]
      },
      "tEventually": {
        "type": "future_operator",
        "ltl_pattern": "F( {cond} )",
        "useFor": ["liveness", "guaranteed completion", "non-urgent goals"]
      },
      "tNext": {
        "type": "future_operator",
        "ltl_pattern": "X( {cond} )",
        "useFor": ["immediate next state", "step-by-step transitions"]
      },
      "tUntil": {
        "type": "future_operator",
        "ltl_pattern": "( {cond} U {act} )",
        "useFor": ["maintenance", "pre-conditions until trigger"]
      },
      "tHistorical": {
        "type": "past_operator",
        "ltl_pattern": "H( {cond} )",
        "useFor": ["past invariants", "audit logs", "unchanged history"]
      },
      "tOnce": {
        "type": "past_operator",
        "ltl_pattern": "O( {cond} )",
        "useFor": ["history check", "at least one past occurrence"]
      },
      "tPrevious": {
        "type": "past_operator",
        "ltl_pattern": "Y( {cond} )",
        "useFor": ["immediate past state", "last tick analysis"]
      },
      "tSince": {
        "type": "past_operator",
        "ltl_pattern": "( {act} S {cond} )",
        "useFor": ["persistence since event", "post-condition tracking"]
      }
    }
  }
}