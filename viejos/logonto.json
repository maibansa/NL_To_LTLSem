{
  "LogSchemaOntology": {

    "gSnomed": {
      "type": "graph",
      "description": "Clinical concept (disease, symptom, finding).",
      "ltlRole": "semanticPredicate",
      "requiresQuantification": true,
      "useFor": [
        "diseases",
        "symptoms",
        "clinical conditions",
        "patient state expressed as a diagnosis"
      ],
      "defaultRole": "condition",
      "examples": [
        "diabetes",
        "hypertension",
        "fever",
        "allergy",
        "pain"
      ]
    },

    "aActivity": {
      "type": "atomic",
      "description": "Clinical task or procedure.",
      "ltlRole": "propositionalAtom",
      "requiresQuantification": false,
      "useFor": [
        "tests",
        "procedures",
        "nursing tasks",
        "clinical interventions"
      ],
      "defaultRole": "action",
      "examples": [
        "glucose test",
        "vital signs recording",
        "surgery",
        "monitoring"
      ]
    },

    "aActionType": {
      "type": "atomic",
      "description": "Medication administration or action type.",
      "ltlRole": "propositionalAtom",
      "requiresQuantification": false,
      "useFor": [
        "drug administration",
        "therapy",
        "treatment actions"
      ],
      "defaultRole": "action",
      "examples": [
        "paracetamol",
        "analgesia",
        "epinephrine",
        "amlodipine"
      ]
    },

    "aWorkflow": {
      "type": "atomic",
      "description": "Clinical process or protocol.",
      "ltlRole": "propositionalAtom",
      "requiresQuantification": false,
      "useFor": [
        "care pathways",
        "clinical processes"
      ],
      "defaultRole": "state",
      "examples": [
        "post-operative care",
        "chronic management"
      ]
    },
    
    "aActor": {
      "type": "atomic",
      "description": "Agent or professional responsible for performing an action.",
      "ltlRole": "propositionalAtom",
      "requiresQuantification": false,
      "useFor": [
        "healthcare professionals",
        "organizational roles",
        "clinical or technical systems executing actions"
      ],
      "defaultRole": "condition",
      "examples": [
        "Care_Manager",
        "Clinical_System",
        "Lab_Technician",
        "Pharmacist",
        "Physician",
        "Practitioner",
        "Radiologist"
      ]
    },

    "sModelReference": {
      "type": "string",
      "description": "Location or formal context.",
      "ltlRole": "eventFilter",
      "requiresQuantification": true,
      "useFor": [
        "clinical units",
        "hospital locations"
      ],
      "defaultRole": "condition",
      "examples": [
        "ICU",
        "emergency room",
        "ward"
      ]
    }
  }
}